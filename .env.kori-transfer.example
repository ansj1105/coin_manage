# Copy:
#   cp .env.kori-transfer.example .env.kori-transfer
# Run:
#   DOTENV_CONFIG_PATH=.env.kori-transfer node scripts/kori-transfer-worker.mjs
# Or with pm2:
#   DOTENV_CONFIG_PATH=.env.kori-transfer pm2 start scripts/ecosystem.kori-transfer.example.cjs

# mainnet | testnet | custom
NETWORK=mainnet

# Required
PRIVATE_KEY=replace-with-private-key
TO_ADDRESS=replace-with-recipient-address
AMOUNT_KORI=1

# Optional. If omitted, defaults are chosen from NETWORK.
TRON_API_URL=https://api.trongrid.io
TOKEN_CONTRACT_ADDRESS=TBJZD8RwQ1JcQvEP9BTbPbgBCGxUjxSXnn
TRON_API_KEY=replace-with-tron-api-key

# Rate limiting
MAX_REQUESTS_PER_WINDOW=15
WINDOW_MS=1000

# Approximate upstream request cost per transfer.
# Increase this if your provider counts each send as multiple API requests.
REQUEST_COST_PER_SEND=3

# Parallel workers inside one process
MAX_IN_FLIGHT=2

# Extra delay after each send loop in milliseconds
POLL_INTERVAL_MS=0

# TRON fee limit
FEE_LIMIT_SUN=100000000

# true | false
STOP_ON_ERROR=false

# Log tag
LOG_PREFIX=kori-transfer-worker
